# Create a free Gemini API key in Google AI Studio.
GEMINI_API_KEY=replace_with_your_gemini_key

# DEMO_KEY works for initial testing but has low shared limits.
# Create your own free data.gov/USDA FoodData Central key for regular use.
USDA_API_KEY=DEMO_KEY

GEMINI_MODEL=gemini-2.5-flash
DATABASE_PATH=data/foodlens.db
